{
  "schema_version": "mbse-activity-model-v0",
  "document_id": "reference_activity",
  "initial": {
    "target_id": "check_full_reset"
  },
  "actions": [
    {
      "id": "reset_context_variables",
      "label": "Reset Context Variables",
      "executable": {
        "kind": "action_language",
        "module": "tests.reference_model.activity.reference_activity_executables",
        "name": "reset_context_variables"
      },
      "transition": {
        "target_id": "reset_done"
      }
    }
  ],
  "decisions": [
    {
      "id": "check_full_reset",
      "label": "Check Full Reset",
      "condition": {
        "kind": "action_language",
        "module": "tests.reference_model.activity.reference_activity_executables",
        "name": "is_full_reset_requested"
      },
      "true_transition": {
        "target_id": "reset_context_variables"
      },
      "false_transition": {
        "target_id": "reset_skipped"
      }
    }
  ],
  "finals": [
    {
      "id": "reset_done",
      "label": "Reset Done"
    },
    {
      "id": "reset_skipped",
      "label": "Reset Skipped"
    }
  ]
}
