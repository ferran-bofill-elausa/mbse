{
  "version": "2.0.0",
  "options": {
    "env": {
      "TASKS_PATH": "${workspaceFolder}/.vscode/tasks"
    }
  },
  "tasks": [
    {
      "label": "run_opencode_web_gui",
      "type": "shell",
      "command": "${TASKS_PATH}/run_opencode_web_gui.sh"
    },
    {
      "label": "open_example_model",
      "type": "shell",
      "command": "${TASKS_PATH}/open_example_model.sh"
    },
    {
      "label": "run_ci",
      "type": "shell",
      "command": "${TASKS_PATH}/run_ci.sh",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
