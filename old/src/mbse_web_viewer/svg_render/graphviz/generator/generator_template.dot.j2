digraph "{{ view.document_id }}" {
  rankdir=LR;
  compound=true;
  graph [nodesep=0.45, ranksep=0.65];
{% macro render_fragment_cell(fragment) -%}
{%- if fragment.target_payload -%}
<TD ALIGN="LEFT" HREF="" TOOLTIP="{{ fragment.target_payload|e }}">{{ fragment.text|e }}</TD>
{%- else -%}
<TD ALIGN="LEFT">{{ fragment.text|e }}</TD>
{%- endif -%}
{%- endmacro %}
{% macro render_text_line(line) -%}
<TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0"><TR>{%- for fragment in line.fragments %}{{ render_fragment_cell(fragment) }}{%- endfor %}</TR></TABLE></TD></TR>
{%- endmacro %}
{% macro render_state_body(sections) -%}
<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
{%- for section in sections %}
{{ render_text_line(section.title_line) }}
{%- for line in section.lines %}
{{ render_text_line(line) }}
{%- endfor %}
{%- endfor %}
</TABLE>
{%- endmacro %}
{% macro render_edge_label(label_line) -%}
<
<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
{{ render_text_line(label_line) }}
</TABLE>
>
{%- endmacro %}
{% macro render_edge_label_lines(label_lines) -%}
<
<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0">
{%- for label_line in label_lines %}
{{ render_text_line(label_line) }}
{%- endfor %}
</TABLE>
>
{%- endmacro %}
{% macro render_state_label(state) -%}
<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR><TD BGCOLOR="{{ state.fill_rgb }}"><B>{{ state.title_text }}</B></TD></TR>
{%- if state.body_sections %}
  <TR><TD ALIGN="LEFT" BALIGN="LEFT">{{ render_state_body(state.body_sections) }}</TD></TR>
{%- else %}
  <TR><TD ALIGN="LEFT">&#160;</TD></TR>
{%- endif %}
</TABLE>
>
{%- endmacro %}
{% macro render_guard_nodes() %}
{% for guard in view.guard_nodes %}
    "{{ guard.id }}" [id="{{ guard.id }}", shape=diamond, label="", xlabel="{{ guard.title_text|e }}"];
{% endfor %}
{% endmacro %}
{% macro render_routing_helpers(parent_id) %}
{% for helper in view.routing_helpers if helper.parent_id == parent_id %}
{% if helper.visibility == "visible_source" %}
    "{{ helper.id }}" [shape=point, label="", width=0.1, height=0.1, fixedsize=true, style=filled, fillcolor=black, color=black];
{% else %}
    "{{ helper.id }}" [shape=point, label="", width=0.1, height=0.1, fixedsize=true, style=invis];
{% endif %}

{% endfor %}
{% endmacro %}
{% macro render_states(parent_id) %}
{% for state in view.state_nodes if state.parent_id == parent_id %}
{% if state.child_state_ids %}
  subgraph "cluster_{{ state.id }}" {
    id="{{ state.id }}";
    bgcolor="{{ state.fill_rgb }}";
    label={{ render_state_label(state) }};
{{ render_routing_helpers(state.id) }}
{{ render_states(state.id) }}
  }
{% else %}
    "{{ state.id }}" [id="{{ state.id }}", shape=box, label={{ render_state_label(state) }}, style="filled", fillcolor="{{ state.fill_rgb }}"];
{% endif %}
{% endfor %}
{% endmacro %}
{{ render_routing_helpers(none) }}
{{ render_states(none) }}
{{ render_guard_nodes() }}
{% for edge in view.initial_edges %}
  "{{ edge.source_id }}" -> "{{ edge.target_id }}" [id="{{ edge.id }}", label=""{% if edge.source_cluster_id %}, ltail="cluster_{{ edge.source_cluster_id }}"{% endif %}{% if edge.target_cluster_id %}, lhead="cluster_{{ edge.target_cluster_id }}"{% endif %}];
{% endfor %}
{% for edge in view.transition_edges %}
  "{{ edge.source_id }}" -> "{{ edge.target_id }}" [id="{{ edge.id }}", {% if edge.label_line %}label={{ render_edge_label(edge.label_line) }}{% else %}label=""{% endif %}{% if edge.xlabel_line %}, xlabel={{ render_edge_label(edge.xlabel_line) }}{% endif %}{% if edge.source_cluster_id %}, ltail="cluster_{{ edge.source_cluster_id }}"{% endif %}{% if edge.target_cluster_id %}, lhead="cluster_{{ edge.target_cluster_id }}"{% endif %}];
{% endfor %}
}
