{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mbse.local/schema/hsm-v1",
  "title": "MBSE HSM JSON v1",
  "description": "Authoritative schema for validated MBSE HSM model documents.",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "variables",
    "events",
    "initial_transition",
    "states"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "description": "Schema discriminator for HSM JSON v1 documents.",
      "const": "hsm-v1"
    },
    "document_id": {
      "description": "Global document identifier.",
      "$ref": "#/$defs/id"
    },
    "variables": {
      "description": "Declared runtime variables and their default values.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/variable"
      }
    },
    "events": {
      "description": "Event declarations addressable by transitions.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "initial_transition": {
      "description": "Required root initial route.",
      "$ref": "#/$defs/initial_transition"
    },
    "states": {
      "description": "Top-level state tree in authored order.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/state"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "callable_ref": {
      "description": "Reference to a Python guard or activity as {module, name}.",
      "type": "object",
      "required": ["module", "name"],
      "additionalProperties": false,
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "variable": {
      "type": "object",
      "required": ["id", "default"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "default": {
          "description": "Default runtime value for this declared HSM variable."
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        }
      }
    },
    "initial_transition": {
      "type": "object",
      "required": ["id", "target_id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "target_id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "hooks": {
      "type": "object",
      "required": ["on_entry", "on_initial", "on_exit"],
      "additionalProperties": false,
      "properties": {
        "on_entry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "on_initial": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "on_exit": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "guard_branch": {
      "description": "Branch target and optional activities for one guard outcome.",
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "$ref": "#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "embedded_guard": {
      "type": "object",
      "required": ["guard", "true_branch", "false_branch"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "guard": {
          "$ref": "#/$defs/callable_ref"
        },
        "true_branch": {
          "$ref": "#/$defs/guard_branch"
        },
        "false_branch": {
          "$ref": "#/$defs/guard_branch"
        }
      }
    },
    "external_transition": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "target_id": {
          "$ref": "#/$defs/id"
        },
        "event_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/id"
            },
            {
              "type": "null"
            }
          ]
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "guard": {
          "$ref": "#/$defs/embedded_guard"
        }
      },
      "oneOf": [
        {
          "required": ["target_id"],
          "not": {
            "required": ["guard"]
          }
        },
        {
          "required": ["guard"],
          "not": {
            "required": ["target_id"]
          }
        }
      ]
    },
    "internal_transition": {
      "description": "Internal handler that consumes an event without changing active state.",
      "type": "object",
      "required": ["id", "event_id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "event_id": {
          "$ref": "#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "state": {
      "description": "Recursive state node with grouped hooks and state-owned transitions.",
      "type": "object",
      "required": [
        "id",
        "states",
        "hooks",
        "external_transitions",
        "internal_transitions"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state"
          }
        },
        "hooks": {
          "$ref": "#/$defs/hooks"
        },
        "initial_transition": {
          "$ref": "#/$defs/initial_transition"
        },
        "external_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_transition"
          }
        },
        "internal_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/internal_transition"
          }
        }
      }
    }
  }
}
