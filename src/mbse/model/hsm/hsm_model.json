{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mbse.local/schema/mbse-hsm-model-v0",
  "title": "MBSE HSM model v0",
  "description": "MBSE HSM model v0.",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "events",
    "initial_transition",
    "states"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "description": "MBSE HSM model v0.",
      "const": "mbse-hsm-model-v0"
    },
    "document_id": {
      "description": "Global document identifier.",
      "$ref": "#/$defs/id"
    },
    "enums": {
      "description": "Global enumerations reusable across variables and event parameters.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/enum"
      }
    },
    "variables": {
      "description": "Declared runtime variables and their default values.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/variable"
      }
    },
    "events": {
      "description": "Event declarations.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "initial_transition": {
      "description": "Required root initial transition.",
      "$ref": "#/$defs/initial_transition"
    },
    "states": {
      "description": "Top-level states.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/state"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "callable_ref": {
      "description": "Reference to a Python activity as {module, name}.",
      "type": "object",
      "required": ["module", "name"],
      "additionalProperties": false,
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "typed_value_base": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signed": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "signed"
            },
            "min": {
              "type": "integer"
            },
            "max": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "unsigned": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "unsigned"
            },
            "min": {
              "type": "integer",
              "minimum": 0
            },
            "max": {
              "type": "integer"
            }
          }
        }
      ]
    },
    "float": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "type": {
              "const": "float"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          }
        }
      ]
    },
    "bool": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "bool"
            }
          }
        }
      ]
    },
    "enum": {
      "type": "object",
      "required": ["id", "values"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "enum_value": {
      "allOf": [
        {
          "$ref": "#/$defs/typed_value_base"
        },
        {
          "type": "object",
          "required": ["enum_id"],
          "properties": {
            "type": {
              "const": "enum"
            },
            "enum_id": {
              "$ref": "#/$defs/id"
            }
          }
        }
      ]
    },
    "parameter": {
      "oneOf": [
        {
          "$ref": "#/$defs/signed"
        },
        {
          "$ref": "#/$defs/unsigned"
        },
        {
          "$ref": "#/$defs/float"
        },
        {
          "$ref": "#/$defs/bool"
        },
        {
          "$ref": "#/$defs/enum_value"
        }
      ]
    },
    "variable": {
      "oneOf": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/signed"
            },
            {
              "type": "object",
              "required": ["default_value"],
              "properties": {
                "default_value": {
                  "type": "integer",
                  "description": "Default value for this declared HSM variable."
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/unsigned"
            },
            {
              "type": "object",
              "required": ["default_value"],
              "properties": {
                "default_value": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Default value for this declared HSM variable."
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/float"
            },
            {
              "type": "object",
              "required": ["default_value"],
              "properties": {
                "default_value": {
                  "type": "number",
                  "description": "Default value for this declared HSM variable."
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/bool"
            },
            {
              "type": "object",
              "required": ["default_value"],
              "properties": {
                "default_value": {
                  "type": "boolean",
                  "description": "Default value for this declared HSM variable."
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/enum_value"
            },
            {
              "type": "object",
              "required": ["default_value"],
              "properties": {
                "default_value": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Default value for this declared HSM variable."
                }
              }
            }
          ]
        }
      ]
    },
    "event": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        }
      }
    },
    "initial_transition": {
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "hooks": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "properties": {
        "on_entry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "on_initial": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "on_exit": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "guard_condition": {
      "type": "object",
      "required": ["guard_activity", "true_branch", "false_branch"],
      "additionalProperties": false,
      "properties": {
        "guard_activity": {
          "$ref": "#/$defs/callable_ref"
        },
        "true_branch": {
          "$ref": "#/$defs/guard_branch"
        },
        "false_branch": {
          "$ref": "#/$defs/guard_branch"
        }
      }
    },
    "guard_branch": {
      "description": "Branch target and optional activities for one guard condition outcome.",
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "$ref": "#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "external_transition": {
      "type": "object",
      "required": ["event_id"],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "#/$defs/id"
        },
        "target_id": {
          "$ref": "#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        },
        "guard_condition": {
          "$ref": "#/$defs/guard_condition"
        }
      },
      "oneOf": [
        {
          "required": ["target_id"],
          "not": {
            "required": ["guard_condition"]
          }
        },
        {
          "required": ["guard_condition"],
          "not": {
            "required": ["target_id"]
          }
        }
      ]
    },
    "internal_transition": {
      "description": "Internal handler that consumes an event without changing active state.",
      "type": "object",
      "required": ["event_id", "activities"],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "#/$defs/id"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callable_ref"
          }
        }
      }
    },
    "state": {
      "description": "State with optional nested states, hooks, and transitions.",
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state"
          }
        },
        "hooks": {
          "$ref": "#/$defs/hooks"
        },
        "initial_transition": {
          "$ref": "#/$defs/initial_transition"
        },
        "external_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_transition"
          }
        },
        "internal_transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/internal_transition"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["initial_transition"]
          },
          "then": {
            "required": ["states"],
            "properties": {
              "states": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
